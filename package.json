{
  "name": "ruzza-orologi",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sync:commerce": "node scripts/sync-commerce.mjs",
    "sync:commerce:check": "node scripts/sync-commerce.mjs --dry-run",
    "build": "tsc --noEmit && vite build",
    "postbuild": "node scripts/finalize-build.mjs dist",
    "build:fresh": "npm run sync:commerce && npm run build",
    "build:cloudflare": "VITE_BASE_PATH=/ vite build --outDir dist-cloudflare && node scripts/finalize-build.mjs dist-cloudflare",
    "go-live:preflight": "node scripts/ruzza-go-live-preflight.mjs",
    "ios:init": "cap add ios",
    "ios:assets": "node scripts/prepare-ios-app-assets.mjs",
    "ios:sync": "pnpm run build && cap sync ios && node scripts/finalize-build.mjs ios/App/App/public",
    "ios:open": "cap open ios",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "framer-motion": "^11.3.8",
    "lenis": "^1.1.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "serve": "^14.2.6",
    "three": "^0.185.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4",
    "vite": "^5.3.5"
  },
  "allowScripts": {
    "esbuild@0.21.5": true
  }
}
