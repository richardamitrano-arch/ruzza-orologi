# ===== Segretaria WhatsApp Ruzza — variabili d'ambiente =====
# 1) Copia questo file in `.env.secretary`  2) riempi i valori  3) lancia:  node tools/whatsapp-preflight.mjs
# In PRODUZIONE (Cloudflare Pages) le stesse chiavi vanno in: Settings → Environment variables.
# NON committare `.env.secretary` (contiene segreti) → aggiungilo a .gitignore.

# ---- Cervello (Anthropic) ----
ANTHROPIC_API_KEY=
SECRETARY_MODEL=claude-sonnet-5
SECRETARY_SUPERVISOR_MODEL=claude-haiku-4-5-20251001

# ---- WhatsApp Cloud API (Meta) ----
# UN token System User long-lived copre TUTTI i numeri dello stesso Business (non serve un token per numero).
WHATSAPP_TOKEN=
# Stringa a tua scelta, la reinserisci identica in Meta quando configuri il webhook.
WHATSAPP_VERIFY_TOKEN=
# App Secret dell'app Meta → firma X-Hub-Signature-256 dei webhook. OBBLIGATORIO: senza, il webhook rifiuta tutto (fail-closed).
WHATSAPP_APP_SECRET=
SECRETARY_GRAPH_VERSION=v21.0

# ---- Numeri per canale ----
# IMPORTANTE: qui va il phone_number_id (ID dato da Meta), NON il numero di telefono.
# Il canale "orologi" usa il prefisso WHATSAPP_WATCHES_*  (naming storico).
#
# OROLOGI → +39 331 968 9707  (store ruzza-orologi, il tuo)
WHATSAPP_WATCHES_PHONE_NUMBER_ID=
WHATSAPP_WATCHES_BUSINESS_NUMBER=393319689707
# WHATSAPP_WATCHES_TOKEN=            # solo se questo numero è su un Business diverso dal token globale
#
# BORSE → +39 320 386 3817  (ruzzabags/ruzzawatch, numero condiviso — verificare chi lo controlla)
WHATSAPP_BAGS_PHONE_NUMBER_ID=
WHATSAPP_BAGS_BUSINESS_NUMBER=393203863817
# WHATSAPP_BAGS_TOKEN=
#
# LUXURY → numero da confermare con Lorenzo (dedicato? oppure = orologi?)
WHATSAPP_LUXURY_PHONE_NUMBER_ID=
WHATSAPP_LUXURY_BUSINESS_NUMBER=
# WHATSAPP_LUXURY_TOKEN=

# ---- Dashboard / cockpit ----
SECRETARY_DASHBOARD_TOKEN=
# Origin da cui la segretaria legge il catalogo (dominio del sito, es. il live). OBBLIGATORIO: se vuoto, catalogo vuoto (nessun fallback).
SECRETARY_SITE_ORIGIN=

# ---- Comportamento ----
SECRETARY_ACTIVE_HOURS=19:00-10:00
SECRETARY_TZ=Europe/Rome
SECRETARY_CATALOG_TTL=600
SECRETARY_RATE_CAP=25             # max messaggi/ora per singolo mittente prima di raccogliere-e-basta (anti-abuso + costo LLM)
SECRETARY_DAILY_CAP=400           # max turni LLM al GIORNO su tutti i numeri (backstop di costo); oltre = solo raccolta
# SECRETARY_CONV_TTL=15552000     # retention conversazioni in secondi (default 180 giorni, si rinnova ad ogni messaggio)
# SECRETARY_SHOP_PHONE=            # numero del NEGOZIO da dare al cliente per chiamate IN ENTRATA (opzionale)
# SECRETARY_PAUSED=true            # RACCOGLIE e basta (zero LLM, zero invii) — accensione sicura a costo zero per il primo giro

# ---- KV (binding, NON una env) ----
# Su Cloudflare Pages: crea un KV namespace e bindalo con nome  SECRETARY_KV
